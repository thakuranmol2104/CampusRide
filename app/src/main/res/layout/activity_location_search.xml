<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Select pickup or drop"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <EditText
        android:id="@+id/etLocationSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_location_result"
        android:hint="Search campus, area, landmark"
        android:imeOptions="actionSearch"
        android:inputType="textPostalAddress"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

    <LinearLayout
        android:id="@+id/layoutCurrentLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_current_location"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="58dp"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_location_pin"
            android:gravity="center"
            android:text="GPS"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Use current location"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentLocationSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Fastest way to pick nearby spot"
                android:textColor="@color/primary"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressLocationSearch"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSearchState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Start typing for quick suggestions"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLocationResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />

</LinearLayout>
